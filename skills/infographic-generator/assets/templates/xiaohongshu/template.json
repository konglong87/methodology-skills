      },
      {
        "name": "business",
        "primary_color": "#2C3E50",
        "secondary_color": "#3498DB",
        "background_color": "#ECF0F1",
        "text_color": "#2C3E50",
        "accent_color": "#E77C3C"
      },
      {
        "name": "handdrawn",
        "primary_color": "#4A4A4A",
        "secondary_color": "#8B4513",
        "background_color": "#FFFAF0",
        "text_color": "#333333",
        "accent_color": "#FF6347"
      },
      {
        "name": "flat",
        "primary_color": "#3498DB",
        "secondary_color": "#2ECC71",
        "background_color": "#FFFFFF",
        "text_color": "#2C3E50",
        "accent_color": "#E77C3C"
      }
    ],
    "customizable": [
      "primary_color",
      "secondary_color",
      "background_color",
      "text_color",
      "accent_color"
    ]
  },
  "output": {
    "format": "PNG",
    "width": 1080,
    "height": 1920,
    "dpi": 300,
    "padding": {
      "top": 80,
      "bottom": 80,
      "left": 60,
      "right": 60
    }
  },
  "example": {
