{
  "template_id": "data_visualization",
  "template_name": "数据展示模板",
  "template_type": "data",
  "description": "适合数据统计、性能对比、指标展示等场景",
  "layout": {
    "type": "vertical",
    "sections": [
      {
        "id": "title_area",
        "type": "title",
        "height": "12%",
        "content": {
          "main_title": {
            "font_size": 42,
            "font_weight": "bold",
            "color": "primary",
            "alignment": "center"
          },
          "subtitle": {
            "font_size": 18,
            "font_weight": "normal",
            "color": "secondary",
            "alignment": "center"
          }
        }
      },
      {
        "id": "metrics_area",
        "type": "metrics",
        "height": "30%",
        "content": {
          "layout": "grid",
          "columns": 3,
          "spacing": 20,
          "metric": {
            "value": {
              "font_size": 36,
              "font_weight": "bold",
              "color": "primary"
            },
            "label": {
              "font_size": 16,
              "font_weight": "normal",
              "color": "text"
            },
            "trend": {
              "font_size": 14,
              "color": "positive"
            }
          }
        }
      },
      {
        "id": "chart_area",
        "type": "chart",
        "height": "45%",
        "content": {
          "chart_type": "bar",
          "orientation": "horizontal",
          "bars": {
            "height": 40,
            "spacing": 15,
            "label": {
              "font_size": 16,
              "font_weight": "normal",
              "color": "text"
            },
            "value": {
              "font_size": 14,
              "font_weight": "bold",
              "color": "white"
            }
          },
          "axis": {
            "show": true,
            "color": "gray"
          }
        }
      },
      {
        "id": "insight_area",
        "type": "insight",
        "height": "13%",
        "content": {
          "text": {
            "font_size": 16,
            "font_weight": "normal",
            "color": "text",
            "alignment": "center"
          },
          "icon": "💡"
        }
      }
    ]
  },
  "style": {
    "default": {
      "primary_color": "#1976D2",
      "secondary_color": "#42A5F5",
      "positive_color": "#4CAF50",
      "negative_color": "#F44336",
      "background_color": "#FFFFFF",
      "text_color": "#333333"
    },
    "customizable": [
      "primary_color",
      "secondary_color",
      "positive_color"
    ]
  },
  "output": {
    "format": "PNG",
    "width": 1200,
    "height": 800,
    "dpi": 300,
    "padding": {
      "top": 40,
      "bottom": 40,
      "left": 40,
      "right": 40
    }
  },
  "example": {
    "title": "MongoDB vs MySQL 性能对比",
    "subtitle": "基准测试数据 (ops/sec)",
    "metrics": [
      {
        "value": "15K",
        "label": "MongoDB写入",
        "trend": "+200%"
      },
      {
        "value": "12K",
        "label": "MySQL查询",
        "trend": "+150%"
      },
      {
        "value": "8K",
        "label": "MySQL关联",
        "trend": "+800%"
      }
    ],
    "chart_data": [
      {
        "label": "单条插入",
        "value": 10000,
        "max": 15000,
        "color": "#4DB33D"
      },
      {
        "label": "批量插入",
        "value": 50000,
        "max": 60000,
        "color": "#4DB33D"
      },
      {
        "label": "简单查询",
        "value": 15000,
        "max": 20000,
        "color": "#4DB33D"
      },
      {
        "label": "复杂关联",
        "value": 8000,
        "max": 10000,
        "color": "#00758F"
      }
    ],
    "insight": "MongoDB适合高并发写入，MySQL适合复杂关联查询"
  }
}