{
  "template_id": "process_flow",
  "template_name": "流程说明模板",
  "template_type": "process",
  "description": "适合步骤说明、流程展示、操作指南等场景",
  "layout": {
    "type": "vertical",
    "sections": [
      {
        "id": "title_area",
        "type": "title",
        "height": "15%",
        "content": {
          "main_title": {
            "font_size": 42,
            "font_weight": "bold",
            "color": "primary",
            "alignment": "center"
          },
          "subtitle": {
            "font_size": 20,
            "font_weight": "normal",
            "color": "secondary",
            "alignment": "center"
          }
        }
      },
      {
        "id": "process_area",
        "type": "process",
        "height": "70%",
        "content": {
          "layout": "vertical_flow",
          "steps": {
            "spacing": 20,
            "connection_style": "arrow",
            "step": {
              "number": {
                "size": 40,
                "style": "circle",
                "color": "primary",
                "background": "light_primary"
              },
              "title": {
                "font_size": 24,
                "font_weight": "bold",
                "color": "primary"
              },
              "description": {
                "font_size": 16,
                "font_weight": "normal",
                "color": "text"
              },
              "details": {
                "layout": "bullet_list",
                "font_size": 14,
                "color": "text"
              }
            }
          }
        }
      },
      {
        "id": "tips_area",
        "type": "tips",
        "height": "15%",
        "content": {
          "title": {
            "font_size": 18,
            "font_weight": "bold",
            "color": "primary"
          },
          "tips": {
            "layout": "list",
            "font_size": 14,
            "color": "text",
            "icon": "💡"
          }
        }
      }
    ]
  },
  "style": {
    "default": {
      "primary_color": "#1976D2",
      "secondary_color": "#42A5F5",
      "light_primary": "#E3F2FD",
      "background_color": "#FFFFFF",
      "text_color": "#333333"
    },
    "customizable": [
      "primary_color",
      "secondary_color",
      "light_primary"
    ]
  },
  "output": {
    "format": "PNG",
    "width": 1200,
    "height": 1600,
    "dpi": 300,
    "padding": {
      "top": 60,
      "bottom": 60,
      "left": 40,
      "right": 40
    }
  },
  "example": {
    "title": "数据库选型决策流程",
    "subtitle": "3步做出正确选择",
    "steps": [
      {
        "number": 1,
        "title": "评估数据特性",
        "description": "分析数据结构、关联需求、数据量级",
        "details": [
          "数据结构是否固定？",
          "是否需要复杂关联？",
          "数据量级如何？"
        ]
      },
      {
        "number": 2,
        "title": "评估业务需求",
        "description": "分析一致性、并发、事务需求",
        "details": [
          "是否需要强一致性？",
          "是否需要高并发写入？",
          "是否需要复杂事务？"
        ]
      },
      {
        "number": 3,
        "title": "评估团队能力",
        "description": "考虑技术栈熟悉度和运维能力",
        "details": [
          "团队熟悉哪个技术栈？",
          "运维能力如何？",
          "学习成本评估"
        ]
      }
    ],
    "tips": [
      "不确定时从MySQL开始",
      "快速验证阶段可选MongoDB",
      "小规模测试验证选型"
    ]
  }
}