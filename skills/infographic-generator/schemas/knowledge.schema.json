{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "knowledge-template.schema.json",
  "title": "Knowledge Template Schema",
  "description": "Knowledge 模板的数据结构验证规范",
  "type": "object",
  "required": ["template", "content"],
  "properties": {
    "template": {
      "const": "knowledge",
      "description": "模板类型必须是 knowledge"
    },
    "output": {
      "type": "string",
      "pattern": "\\.png$",
      "description": "输出文件名，必须以 .png 结尾"
    },
    "content": {
      "type": "object",
      "required": ["title", "items"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 2,
          "maxLength": 100,
          "description": "主标题，2-100字符"
        },
        "subtitle": {
          "type": "string",
          "maxLength": 100,
          "description": "副标题，最多100字符"
        },
        "meta_info": {
          "type": "string",
          "description": "元信息"
        },
        "items": {
          "type": "array",
          "minItems": 2,
          "maxItems": 6,
          "description": "要点数组，2-6个要点",
          "items": {
            "type": "object",
            "required": ["title", "description"],
            "properties": {
              "icon": {
                "type": "string",
                "description": "图标 emoji"
              },
              "title": {
                "type": "string",
                "minLength": 2,
                "maxLength": 50,
                "description": "要点标题"
              },
              "description": {
                "type": "string",
                "minLength": 5,
                "maxLength": 200,
                "description": "要点描述"
              }
            }
          }
        },
        "summary": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "description": "总结数组，1-3条",
          "items": {
            "type": "string",
            "minLength": 10
          }
        }
      }
    },
    "style": {
      "type": "object",
      "description": "样式配置"
    },
    "style_name": {
      "type": "string",
      "description": "风格名称"
    },
    "output_config": {
      "type": "object",
      "properties": {
        "width": {
          "type": "number",
          "enum": [1080, 1920]
        },
        "height": {
          "type": "number",
          "enum": [1080, 1920]
        },
        "orientation": {
          "type": "string",
          "enum": ["horizontal", "vertical"]
        }
      }
    }
  }
}