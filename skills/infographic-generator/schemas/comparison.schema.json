{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "comparison-template.schema.json",
  "title": "Comparison Template Schema",
  "description": "Comparison 模板的数据结构验证规范 - 仅支持两个对象的对比",
  "type": "object",
  "required": ["template", "content"],
  "properties": {
    "template": {
      "const": "comparison",
      "description": "模板类型必须是 comparison"
    },
    "output": {
      "type": "string",
      "pattern": "\\.png$"
    },
    "content": {
      "type": "object",
      "required": [
        "title",
        "left_title",
        "left_icon",
        "left_items",
        "right_title",
        "right_icon",
        "right_items"
      ],
      "properties": {
        "title": {
          "type": "string",
          "description": "主标题"
        },
        "subtitle": {
          "type": "string"
        },

        "left_title": {
          "type": "string",
          "description": "左侧对象标题"
        },
        "left_icon": {
          "type": "string",
          "description": "左侧对象图标"
        },
        "left_bg": {
          "type": "string",
          "description": "左侧背景色"
        },
        "left_primary": {
          "type": "string",
          "description": "左侧主色调"
        },
        "left_items": {
          "type": "array",
          "minItems": 1,
          "maxItems": 6,
          "description": "左侧对比要点",
          "items": {
            "type": "object",
            "required": ["label", "value"],
            "properties": {
              "icon": {
                "type": "string"
              },
              "label": {
                "type": "string",
                "description": "要点标签"
              },
              "value": {
                "type": "string",
                "description": "要点值"
              }
            }
          }
        },

        "right_title": {
          "type": "string",
          "description": "右侧对象标题"
        },
        "right_icon": {
          "type": "string",
          "description": "右侧对象图标"
        },
        "right_bg": {
          "type": "string",
          "description": "右侧背景色"
        },
        "right_primary": {
          "type": "string",
          "description": "右侧主色调"
        },
        "right_items": {
          "type": "array",
          "minItems": 1,
          "maxItems": 6,
          "description": "右侧对比要点",
          "items": {
            "type": "object",
            "required": ["label", "value"],
            "properties": {
              "icon": {
                "type": "string"
              },
              "label": {
                "type": "string"
              },
              "value": {
                "type": "string"
              }
            }
          }
        },

        "conclusion": {
          "type": "string",
          "description": "对比结论"
        },
        "recommendation": {
          "type": "string",
          "description": "推荐建议"
        }
      }
    }
  }
}